# Django Application Settings
SECRET_KEY=your-production-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.render.com

# Database Connection (PostgreSQL for Production, defaults to SQLite if left empty)
DATABASE_URL=postgres://user:password@localhost:5432/linkforge

# Cache & Message Broker (Redis)
REDIS_URL=redis://localhost:6379/0

# Rate Limiting & URL Configuration
RATE_LIMIT_CREATION_LIMIT=100
RATE_LIMIT_CREATION_WINDOW=3600
SHORT_CODE_LENGTH=6

# Logging Config
DJANGO_LOG_LEVEL=INFO
